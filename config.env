# =============================================================================
# Benchmark-Lab Configuration
# =============================================================================
# This file is sourced by run_experiments.sh and my_test.sh.
# Edit values here instead of passing CLI flags every time.
# CLI flags (e.g. --bucket) still override these defaults.
# =============================================================================

# ---- Run Configuration ----
# "local" = runs on this machine via Docker Compose
# "batch" = submits job to AWS Batch
EXPERIMENT_MODE="local"

# ---- AWS General ----
AWS_REGION="us-east-2"
S3_BUCKET="experiment-sandbox"
# S3 key prefix under which results are stored (run key is appended)
S3_PREFIX="ruidi-prl-benchmark"

# ---- AWS ECR ----
# ECR repository URI for pushing the experiment image (batch mode only)
# e.g. 123456789012.dkr.ecr.us-east-2.amazonaws.com/benchmark-lab
ECR_REPO="411614151856.dkr.ecr.us-east-2.amazonaws.com/experiments/prl-benchmarking"

# ---- AWS Batch ----
# These fields are ONLY used when EXPERIMENT_MODE="batch"
BATCH_JOB_DEFINITION="experiment-general-definition:5"
BATCH_JOB_QUEUE="experiments-sandbox-ec2"

# Container-level resource overrides (sent with each job submission).
# Set to "" to use the defaults baked into the job definition.
# ONLY used when EXPERIMENT_MODE="batch"
BATCH_VCPUS="4"            # Number of vCPUs for the container
BATCH_MEMORY="16384"       # Memory in MiB (16384 = 16 GB)
BATCH_GPUS=""              # Number of GPUs (leave empty for none)

# ---- Local / Docker ----
# Extra flags passed to `docker compose up` (e.g. "--no-build")
DOCKER_COMPOSE_EXTRA_FLAGS=""
